// Event Ticket Booking Platform - Sri Lanka (LKR)
// Prisma Schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --------------------------------------------
// Auth & Users
// --------------------------------------------

enum RoleEnum {
  CUSTOMER
  ORGANIZER
  SUPER_ADMIN
}

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  name           String
  phone          String
  passwordHash   String?   // null if Google-only
  avatarUrl      String?
  organization   String?
  role           RoleEnum  @default(CUSTOMER)
  isPremium      Boolean   @default(false)
  stripeCustomerId String? @unique
  emailVerified  Boolean   @default(false)
  googleId       String?   @unique
  deletedAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  events         Event[]
  bookings       Booking[]
  subscriptions  Subscription[]
  rewardPoints   RewardPoint[]
  refreshTokens  RefreshToken[]

  @@index([email, deletedAt])
  @@index([role])
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  userAgent String?
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

// Pending registration (OTP) and password reset tokens
model VerificationToken {
  id        String   @id @default(cuid())
  email     String
  token     String
  type      String   // REGISTRATION_OTP | PASSWORD_RESET
  meta      Json?    // for REGISTRATION_OTP: { name, phone, passwordHash, organization }
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@unique([email, type])
  @@index([token, type])
}

// --------------------------------------------
// Events & Tickets
// --------------------------------------------

enum EventStatus {
  PENDING
  APPROVED
  REJECTED
}

model Category {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  deletedAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  events Event[]

  @@index([slug])
}

model Event {
  id            String      @id @default(cuid())
  title         String
  slug          String      @unique
  description   String
  location      String
  venue         String?
  eventDate     DateTime
  eventTime     String?     // e.g. "19:00"
  coverImage    String
  seatingImage  String?
  status        EventStatus @default(PENDING)
  rejectedReason String?
  organizerId   String
  categoryId    String?
  bookingOpensAt DateTime?  // if set and in future, show as "coming soon" and block booking
  deletedAt     DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  organizer   User         @relation(fields: [organizerId], references: [id], onDelete: Cascade)
  category   Category?    @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  ticketTypes TicketType[]
  bookings   Booking[]
  eventPaymentMethods EventPaymentMethod[]
  eventFeatures EventFeature[]

  @@index([status, deletedAt])
  @@index([organizerId])
  @@index([categoryId])
  @@index([eventDate])
}

// Paid featuring: organizer pays to show event in "Featured" section for a period (admin-configured price & max duration)
model EventFeature {
  id              String    @id @default(cuid())
  eventId         String
  startsAt        DateTime
  endsAt          DateTime
  amountPaid      Decimal?  @db.Decimal(12, 2)
  stripePaymentId String?
  createdAt       DateTime  @default(now())

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@index([endsAt])
}

model TicketType {
  id          String   @id @default(cuid())
  name        String
  price       Decimal  @db.Decimal(12, 2) // LKR
  quantity    Int
  soldCount   Int      @default(0)
  eventId     String
  deletedAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  event        Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  bookingItems BookingItem[]

  @@index([eventId])
}

// Per-event payment method override (organizer can enable/disable)
model EventPaymentMethod {
  id           String   @id @default(cuid())
  eventId      String
  paymentMethod String  // STRIPE, KOKO, MINTPAY, ON_ENTRY
  enabled      Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, paymentMethod])
  @@index([eventId])
}

// --------------------------------------------
// Bookings & Payments
// --------------------------------------------

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

enum PaymentMethodEnum {
  STRIPE
  KOKO
  MINTPAY
  ON_ENTRY
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
}

model Booking {
  id                String        @id @default(cuid())
  bookingNumber     String        @unique
  eventId           String
  userId            String?       // null for guest
  guestEmail        String?
  guestName         String?
  guestPhone        String?
  status            BookingStatus @default(PENDING)
  subtotal          Decimal       @db.Decimal(12, 2) // LKR
  handlingFee       Decimal       @db.Decimal(12, 2) @default(0)
  discountAmount    Decimal       @db.Decimal(12, 2) @default(0)
  pointsRedeemed   Int           @default(0)
  pointsEarned     Int           @default(0)
  total             Decimal       @db.Decimal(12, 2)
  promotionId       String?
  couponId          String?
  deletedAt         DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  event      Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user       User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  items      BookingItem[]
  payment    Payment?
  promotion  Promotion?    @relation(fields: [promotionId], references: [id], onDelete: SetNull)
  coupon     Coupon?       @relation(fields: [couponId], references: [id], onDelete: SetNull)

  @@index([eventId])
  @@index([userId])
  @@index([bookingNumber])
  @@index([status])
  @@index([createdAt])
}

model BookingItem {
  id           String   @id @default(cuid())
  bookingId    String
  ticketTypeId String
  quantity     Int
  unitPrice    Decimal  @db.Decimal(12, 2)
  total        Decimal  @db.Decimal(12, 2)
  createdAt    DateTime @default(now())

  booking    Booking    @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  ticketType TicketType @relation(fields: [ticketTypeId], references: [id], onDelete: Restrict)

  @@index([bookingId])
}

model Payment {
  id            String         @id @default(cuid())
  bookingId     String         @unique
  method        PaymentMethodEnum
  amount        Decimal        @db.Decimal(12, 2)
  status        PaymentStatus  @default(PENDING)
  stripePaymentId String?
  stripeIntentId  String?
  metadata      Json?
  paidAt        DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([stripePaymentId])
}

// --------------------------------------------
// Promotions & Coupons
// --------------------------------------------

enum PromotionType {
  PERCENTAGE
  FIXED_AMOUNT
  BUY_ONE_GET_ONE
  COUPON
  AUTO
  FLASH
}

model Promotion {
  id              String        @id @default(cuid())
  name            String
  type            PromotionType
  value           Decimal?      @db.Decimal(10, 2) // % or fixed LKR
  minOrderAmount  Decimal?      @db.Decimal(12, 2)
  maxDiscount     Decimal?      @db.Decimal(12, 2)
  startDate       DateTime
  endDate         DateTime
  isFlash         Boolean       @default(false)
  restrictPaymentMethods String? // JSON array e.g. ["STRIPE","KOKO"]
  restrictCustomerType   String? // GUEST, REGISTERED, ALL
  isActive        Boolean       @default(true)
  deletedAt       DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  coupons   Coupon[]
  bookings  Booking[]

  @@index([isActive, startDate, endDate])
}

model Coupon {
  id           String   @id @default(cuid())
  code         String   @unique
  promotionId  String
  maxUses      Int?
  usedCount    Int      @default(0)
  deletedAt    DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  promotion Promotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  bookings  Booking[]

  @@index([code])
}

// --------------------------------------------
// Reward Points
// --------------------------------------------

model RewardPoint {
  id          String   @id @default(cuid())
  userId      String
  points      Int      // can be negative for redemption
  balance     Int      // running balance after this tx
  source      String   // BOOKING_EARN, REDEEM, EXPIRY, ADJUSTMENT
  referenceId String?  // bookingId etc
  expiresAt   DateTime?
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

// --------------------------------------------
// Premium & Subscriptions
// --------------------------------------------

model PremiumPlan {
  id        String   @id @default(cuid())
  name      String
  price     Decimal  @db.Decimal(12, 2) // LKR
  duration  String   // MONTHLY, YEARLY
  stripePriceId String?
  isActive  Boolean  @default(true)
  deletedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subscriptions Subscription[]

  @@index([isActive])
}

model Subscription {
  id             String    @id @default(cuid())
  userId         String
  planId         String
  stripeSubId    String?
  status         String    // active, cancelled, past_due
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  cancelledAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan PremiumPlan  @relation(fields: [planId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@index([stripeSubId])
}

// --------------------------------------------
// Content (Banners, Testimonials)
// --------------------------------------------

model Banner {
  id          String   @id @default(cuid())
  title       String?
  subtitle    String?
  imageUrl    String
  linkUrl     String?
  buttonLabel String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  deletedAt  DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([isActive, sortOrder])
}

model Testimonial {
  id        String   @id @default(cuid())
  author    String
  content   String
  avatarUrl String?
  rating    Int?     // 1-5
  isActive  Boolean  @default(true)
  deletedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
}

// --------------------------------------------
// System Settings (handling fee, points, payment methods, etc.)
// --------------------------------------------

model SystemSettings {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String   // JSON string for complex values
  updatedAt DateTime @updatedAt

  @@index([key])
}
